---
/**
 * DemoControls.astro — Reusable Storybook-like controls panel for interactive demos.
 *
 * Renders a structured control panel with sections, descriptions, and default badges.
 * Emits `control-change` CustomEvents on the container element when any control changes.
 *
 * Usage in a demo:
 * ```astro
 * <div class="grid-demo not-content" id="my-demo">
 *   <DemoControls controls={[
 *     { section: 'DATA', name: 'rowCount', label: 'Row count', type: 'number',
 *       min: 10, max: 10000, step: 10, default: 100, description: 'Number of rows' },
 *     { section: 'LAYOUT', name: 'fitMode', label: 'Fit mode', type: 'radio',
 *       options: ['stretch', 'fixed'], default: 'stretch' },
 *     { section: 'FEATURES', name: 'sortable', label: 'Sortable', type: 'boolean',
 *       default: true },
 *   ]} />
 *   <tbw-grid style="height: 400px;"></tbw-grid>
 * </div>
 * ```
 *
 * Listen in script:
 * ```ts
 * container.addEventListener('control-change', (e) => {
 *   const { name, value, allValues } = e.detail;
 * });
 * ```
 */

export interface ControlDef {
  name: string;
  label: string;
  description?: string;
  type: 'number' | 'boolean' | 'radio' | 'select' | 'check-group';
  default?: unknown;
  section?: string;
  options?: string[];
  min?: number;
  max?: number;
  step?: number;
}

interface Props {
  controls: ControlDef[];
}

const { controls } = Astro.props;

// Group controls by section
const sections = new Map<string, ControlDef[]>();
for (const ctrl of controls) {
  const key = ctrl.section ?? '';
  if (!sections.has(key)) sections.set(key, []);
  sections.get(key)!.push(ctrl);
}
---

<div class="demo-controls" data-controls>
  {[...sections.entries()].map(([sectionName, ctrls]) => (
    <div class="dc-section">
      {sectionName && <div class="dc-section-label">{sectionName}</div>}
      {ctrls.map((ctrl) => (
        <div class="dc-row" data-ctrl-name={ctrl.name}>
          <div class="dc-label-cell">
            <span class="dc-name">{ctrl.label}</span>
            {ctrl.description && <span class="dc-desc">{ctrl.description}</span>}
          </div>
          <div class="dc-widget-cell">
            {ctrl.type === 'number' && (
              <label class="dc-range-wrap">
                <input
                  type="range"
                  data-ctrl={ctrl.name}
                  data-type="number"
                  min={ctrl.min ?? 0}
                  max={ctrl.max ?? 100}
                  step={ctrl.step ?? 1}
                  value={String(ctrl.default ?? ctrl.min ?? 0)}
                />
                <output data-ctrl-output={ctrl.name}>{String(ctrl.default ?? ctrl.min ?? 0)}</output>
              </label>
            )}
            {ctrl.type === 'boolean' && (
              <label class="dc-toggle">
                <input
                  type="checkbox"
                  data-ctrl={ctrl.name}
                  data-type="boolean"
                  checked={ctrl.default === true ? true : undefined}
                />
                <span class="dc-toggle-track"></span>
              </label>
            )}
            {ctrl.type === 'radio' && ctrl.options && (
              <div class="dc-radio-group">
                {ctrl.options.map((opt) => (
                  <label>
                    <input
                      type="radio"
                      name={`dc-${ctrl.name}`}
                      value={opt}
                      data-ctrl={ctrl.name}
                      data-type="radio"
                      checked={ctrl.default === opt ? true : undefined}
                    />
                    {opt}
                  </label>
                ))}
              </div>
            )}
            {ctrl.type === 'select' && ctrl.options && (
              <select data-ctrl={ctrl.name} data-type="select">
                {ctrl.options.map((opt) => (
                  <option value={opt} selected={ctrl.default === opt ? true : undefined}>{opt}</option>
                ))}
              </select>
            )}
            {ctrl.type === 'check-group' && ctrl.options && (
              <div class="dc-check-group">
                {ctrl.options.map((opt) => (
                  <label>
                    <input
                      type="checkbox"
                      data-ctrl-group={ctrl.name}
                      data-type="check-group"
                      value={opt}
                      checked={Array.isArray(ctrl.default) && ctrl.default.includes(opt) ? true : undefined}
                    />
                    {opt}
                  </label>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  ))}
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-controls]').forEach((panel) => {
    const container = panel.parentElement;
    if (!container) return;

    function getAllValues(): Record<string, unknown> {
      const values: Record<string, unknown> = {};

      panel.querySelectorAll<HTMLInputElement>('[data-ctrl]').forEach((el) => {
        const name = el.dataset.ctrl!;
        const type = el.dataset.type;
        if (type === 'number') values[name] = Number(el.value);
        else if (type === 'boolean') values[name] = el.checked;
        else if (type === 'radio') { if (el.checked) values[name] = el.value; }
        else if (type === 'select') values[name] = (el as unknown as HTMLSelectElement).value;
      });

      panel.querySelectorAll<HTMLInputElement>('[data-ctrl-group]').forEach((el) => {
        const name = el.dataset.ctrlGroup!;
        if (!values[name]) values[name] = [];
        if (el.checked) (values[name] as string[]).push(el.value);
      });

      return values;
    }

    function emitChange(name: string, value: unknown) {
      container!.dispatchEvent(
        new CustomEvent('control-change', {
          bubbles: false,
          detail: { name, value, allValues: getAllValues() },
        })
      );
    }

    panel.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      const name = target.dataset.ctrl ?? target.dataset.ctrlGroup;
      if (!name) return;

      const type = target.dataset.type;

      // Update range output
      if (type === 'number') {
        const output = panel.querySelector(`[data-ctrl-output="${name}"]`);
        if (output) output.textContent = target.value;
        emitChange(name, Number(target.value));
      } else if (type === 'boolean') {
        emitChange(name, target.checked);
      } else if (type === 'radio') {
        emitChange(name, target.value);
      } else if (type === 'select') {
        emitChange(name, target.value);
      } else if (type === 'check-group') {
        const checked: string[] = [];
        panel.querySelectorAll<HTMLInputElement>(`[data-ctrl-group="${name}"]`).forEach((cb) => {
          if (cb.checked) checked.push(cb.value);
        });
        emitChange(name, checked);
      }
    });

    panel.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.dataset.type === 'select') {
        emitChange(target.dataset.ctrl!, target.value);
      }
    });
  });
</script>

<style>
  .demo-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    background: var(--sl-color-gray-7);
    font-size: 0.8125rem;
    overflow: hidden;
  }

  .dc-section {
    flex: 1 1 auto;
    min-width: 200px;
    border-right: 1px solid var(--sl-color-gray-6);
    place-self: flex-start;
  }
  .dc-section:last-child {
    border-right: none;
  }

  .dc-section-label {
    padding: 6px 12px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .dc-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }
  .dc-row:last-child {
    border-bottom: none;
  }

  .dc-label-cell {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .dc-name {
    font-weight: 600;
    color: var(--sl-color-gray-2);
    white-space: nowrap;
  }

  .dc-desc {
    font-size: 0.7rem;
    color: var(--sl-color-gray-3);
    line-height: 1.3;
  }

  .dc-widget-cell {
    display: flex;
    align-items: center;
  }

  .dc-range-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .dc-range-wrap input[type="range"] {
    width: 120px;
  }
  .dc-range-wrap output {
    min-width: 3ch;
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-2);
    font-weight: 600;
  }

  /* Slide-toggle for boolean controls */
  .dc-toggle {
    position: relative;
    display: inline-block;
    width: 34px;
    height: 18px;
    cursor: pointer;
  }
  .dc-toggle input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .dc-toggle-track {
    position: absolute;
    inset: 0;
    border-radius: 9px;
    background: var(--sl-color-gray-5);
    transition: background 0.2s;
  }
  .dc-toggle-track::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: white;
    transition: transform 0.2s;
  }
  .dc-toggle input:checked + .dc-toggle-track {
    background: var(--sl-color-accent);
  }
  .dc-toggle input:checked + .dc-toggle-track::after {
    transform: translateX(16px);
  }
  .dc-toggle input:focus-visible + .dc-toggle-track {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .dc-radio-group, .dc-check-group {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .dc-radio-group label, .dc-check-group label {
    display: flex;
    align-items: center;
    gap: 3px;
    cursor: pointer;
    white-space: nowrap;
  }

  select[data-ctrl] {
    padding: 2px 6px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    background: var(--sl-color-gray-7);
    color: var(--sl-color-gray-2);
    font-size: 0.8125rem;
  }

  @media (max-width: 640px) {
    .demo-controls {
      flex-direction: column;
    }
    .dc-section {
      border-right: none;
      border-bottom: 1px solid var(--sl-color-gray-6);
    }
    .dc-section:last-child {
      border-bottom: none;
    }
  }
</style>
