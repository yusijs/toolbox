---
import Default from '@astrojs/starlight/components/Head.astro';
---

<Default {...Astro.props}><slot /></Default>

<!-- Deduplicate title when page title matches site title (e.g. homepage) -->
<script is:inline>
(function() {
  var parts = document.title.split(' | ');
  if (parts.length === 2 && parts[0] === parts[1]) document.title = parts[0];
})();
</script>

<!-- Structured data for search engines -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Toolbox Grid",
  "description": "A high-performance, framework-agnostic data grid web component for JavaScript, React, Angular, and Vue.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "url": "https://toolboxjs.com",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": {
    "@type": "Person",
    "name": "Øystein Amundsen",
    "url": "https://github.com/OysteinAmundsen"
  },
  "license": "https://opensource.org/licenses/MIT",
  "keywords": [
    "datagrid", "data grid", "web component", "javascript", "typescript",
    "react", "angular", "vue", "framework-agnostic", "open source"
  ]
})} />

<!-- Open Graph defaults -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Toolbox Grid Documentation" />
<meta property="og:image" content="https://toolboxjs.com/grid_logo.png" />
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:image" content="https://toolboxjs.com/grid_logo.png" />

<!-- Heading anchor links: copy URL to clipboard on click instead of just navigating -->
<script is:inline>
(function() {
  function setup() {
    document.addEventListener('click', function(e) {
      var link = e.target.closest('.sl-anchor-link');
      if (!link) return;
      e.preventDefault();
      var url = link.href || (location.origin + location.pathname + link.getAttribute('href'));
      // Update the URL hash so it's visible in the address bar
      history.replaceState(null, '', link.getAttribute('href'));
      var icon = link.querySelector('.sl-anchor-icon');
      function flash(state) {
        if (!icon) return;
        icon.dataset.copied = state;
        setTimeout(function() { delete icon.dataset.copied; }, 1500);
      }
      // Copy to clipboard. writeText() requires a secure context and transient
      // user activation (which we have inside this click handler). It can still
      // reject if the page is in an iframe without `clipboard-write` permission
      // or if navigator.clipboard is unavailable (insecure context, very old browser).
      if (!navigator.clipboard || !navigator.clipboard.writeText) {
        flash('failed');
        return;
      }
      navigator.clipboard.writeText(url).then(
        function() { flash('true'); },
        function() { flash('failed'); }
      );
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', setup);
  else setup();
})();
</script>
<style is:global>
  .sl-anchor-icon[data-copied]::after {
    content: 'Copied!';
    position: absolute;
    top: -1.8em;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    background: var(--sl-color-gray-5, #444);
    color: var(--sl-color-text, #fff);
    padding: 0.15em 0.5em;
    border-radius: 4px;
    white-space: nowrap;
    pointer-events: none;
    animation: sl-copied-fade 1.5s ease-out forwards;
  }
  .sl-anchor-icon[data-copied='failed']::after {
    content: 'Copy failed';
    background: var(--sl-color-red, #b91c1c);
  }
  .sl-anchor-icon {
    position: relative;
  }
  @keyframes sl-copied-fade {
    0%, 70% { opacity: 1; }
    100% { opacity: 0; }
  }
</style>

<!-- Sidebar framework icons — injected via script since Starlight has no icon prop on groups -->
<script is:inline>
(function() {
  var icons = {
    Angular: '<svg viewBox="0 0 960 960" fill="#f41343" aria-hidden="true" focusable="false"><polygon points="562.6,109.8 804.1,629.5 829.2,233.1"/><polygon points="624.9,655.9 334.3,655.9 297.2,745.8 479.6,849.8 662,745.8"/><polygon points="384.1,539.3 575.2,539.3 479.6,307"/><polygon points="396.6,109.8 130,233.1 155.1,629.5"/></svg>',
    React: '<svg viewBox="-11.5 -10.232 23 20.463" fill="#00d1f7" aria-hidden="true" focusable="false"><circle r="2.05"/><g stroke="#00d1f7" fill="none" stroke-width="1"><ellipse rx="11" ry="4.2"/><ellipse rx="11" ry="4.2" transform="rotate(60)"/><ellipse rx="11" ry="4.2" transform="rotate(120)"/></g></svg>',
    Vue: '<svg viewBox="0 0 196.32 170.02" aria-hidden="true" focusable="false"><path fill="#42b883" d="M120.83 0L98.16 39.26 75.49 0H0l98.16 170.02L196.32 0h-75.49z"/><path fill="#35495e" d="M120.83 0L98.16 39.26 75.49 0H39.26l58.9 102.01L157.06 0h-36.23z"/></svg>'
  };
  function inject() {
    var labels = document.querySelectorAll('.group-label > .large');
    for (var i = 0; i < labels.length; i++) {
      var text = labels[i].textContent.trim();
      if (icons[text] && !labels[i].querySelector('.sidebar-icon')) {
        var span = document.createElement('span');
        span.className = 'sidebar-icon';
        span.setAttribute('aria-hidden', 'true');
        span.innerHTML = icons[text];
        labels[i].insertBefore(span, labels[i].firstChild);
      }
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', inject);
  else inject();
  document.addEventListener('astro:page-load', inject);
  document.addEventListener('astro:after-swap', inject);
})();
</script>
