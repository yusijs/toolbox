---
/**
 * Custom Header — adds grid theme switcher and framework selector alongside Starlight defaults.
 * Layout: [Logo (sidebar-width)] [ThemeSwitcher | Dark/Light | Search | Framework] [GitHub]
 */
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <div class="sl-flex center-group print:hidden">
    <grid-theme-switcher class="sl-hidden md:sl-flex">
      <label class="theme-select-label">
        <span class="sr-only">Grid Theme</span>
        <svg aria-hidden="true" class="theme-select-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/>
          <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/>
          <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/>
          <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/>
          <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>
        </svg>
        <select aria-label="Grid Theme" autocomplete="off">
          <option value="">Default</option>
          <option value="bootstrap">Bootstrap</option>
          <option value="contrast">Contrast</option>
          <option value="large">Large</option>
          <option value="material">Material</option>
          <option value="standard">Standard</option>
          <option value="vibrant">Vibrant</option>
        </select>
        <svg aria-hidden="true" class="theme-select-caret" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="m6 9 6 6 6-6"/></svg>
      </label>
    </grid-theme-switcher>
    <div class="sl-hidden md:sl-flex">
      <ThemeSelect />
    </div>
    {shouldRenderSearch && <Search />}
    <fw-selector class="sl-hidden md:sl-flex">
      <label class="fw-select-label">
        <span class="sr-only">Framework</span>
        <select aria-label="Framework" autocomplete="off">
          <option value="TypeScript">TypeScript</option>
          <option value="React">React</option>
          <option value="Vue">Vue</option>
          <option value="Angular">Angular</option>
        </select>
      </label>
    </fw-selector>
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
  </div>
</div>

<script>
  import bootstrapCss from '@toolbox/themes/dg-theme-bootstrap.css?raw';
import contrastCss from '@toolbox/themes/dg-theme-contrast.css?raw';
import largeCss from '@toolbox/themes/dg-theme-large.css?raw';
import materialCss from '@toolbox/themes/dg-theme-material.css?raw';
import standardCss from '@toolbox/themes/dg-theme-standard.css?raw';
import vibrantCss from '@toolbox/themes/dg-theme-vibrant.css?raw';

  const THEMES: Record<string, string> = {
    bootstrap: bootstrapCss,
    contrast: contrastCss,
    large: largeCss,
    material: materialCss,
    standard: standardCss,
    vibrant: vibrantCss,
  };

  const STYLE_ID = 'tbw-active-theme';
  const STORAGE_KEY = 'tbw-grid-theme';

  function applyTheme(name: string) {
    document.getElementById(STYLE_ID)?.remove();
    if (!name || !THEMES[name]) {
      document.dispatchEvent(new CustomEvent('tbw-theme-change', { detail: { theme: '' } }));
      return;
    }
    const style = document.createElement('style');
    style.id = STYLE_ID;
    style.textContent = THEMES[name];
    document.head.appendChild(style);
    document.dispatchEvent(new CustomEvent('tbw-theme-change', { detail: { theme: name } }));
  }

  // Apply the persisted theme immediately at module-evaluation time so grids
  // that are already in the DOM render with the correct theme on first paint.
  const savedTheme = localStorage.getItem(STORAGE_KEY) ?? '';
  if (savedTheme) applyTheme(savedTheme);

  class GridThemeSwitcher extends HTMLElement {
    connectedCallback() {
      const select = this.querySelector('select');
      if (!select) return;

      // Sync dropdown to persisted value
      const saved = localStorage.getItem(STORAGE_KEY) ?? '';
      if (saved) select.value = saved;

      select.addEventListener('change', () => {
        const theme = select.value;
        localStorage.setItem(STORAGE_KEY, theme);
        applyTheme(theme);
      });
    }
  }

  if (!customElements.get('grid-theme-switcher')) {
    customElements.define('grid-theme-switcher', GridThemeSwitcher);
  }
</script>

<script>
  const FW_STORAGE_KEY = 'starlight-synced-tabs__framework';

  // SVG icons injected at runtime — keeps Astro/parse5 from mangling rich
  // <option> content (parse5 follows the legacy spec where <option> is text-only
  // and drops trailing close tags when it sees <svg>/<span> children).
  const FW_ICONS: Record<string, string> = {
    TypeScript:
      '<svg aria-hidden="true" class="fw-opt-icon" viewBox="0 0 256 256" width="16" height="16"><rect width="256" height="256" rx="24" fill="#3178c6"/><path fill="#fff" d="M150.518 200.475v27.62c4.492 2.302 9.805 4.028 15.938 5.179 6.133 1.151 12.597 1.726 19.393 1.726 6.622 0 12.914-.633 18.874-1.899 5.96-1.266 11.187-3.352 15.678-6.257 4.492-2.906 8.048-6.704 10.669-11.394 2.62-4.689 3.93-10.486 3.93-17.391 0-5.006-.749-9.394-2.246-13.163a30.748 30.748 0 0 0-6.479-9.985c-2.821-2.935-6.205-5.567-10.149-7.898-3.945-2.33-8.394-4.531-13.347-6.602-3.628-1.497-6.881-2.949-9.762-4.359-2.879-1.41-5.327-2.848-7.342-4.316-2.016-1.467-3.571-3.021-4.665-4.661-1.094-1.64-1.641-3.495-1.641-5.567 0-1.899.489-3.61 1.468-5.135.978-1.525 2.362-2.834 4.147-3.927 1.785-1.094 3.973-1.942 6.565-2.547 2.591-.604 5.471-.906 8.638-.906 2.304 0 4.737.173 7.299.518 2.563.345 5.14.877 7.732 1.597a53.669 53.669 0 0 1 7.558 2.719 41.7 41.7 0 0 1 6.781 3.797v-25.807c-4.204-1.611-8.797-2.805-13.778-3.582-4.981-.777-10.697-1.165-17.147-1.165-6.565 0-12.784.705-18.658 2.115-5.874 1.409-11.043 3.61-15.506 6.602-4.463 2.993-7.99 6.805-10.582 11.437-2.591 4.632-3.887 10.17-3.887 16.615 0 8.228 2.375 15.248 7.127 21.06 4.751 5.811 11.964 10.731 21.638 14.759 3.801 1.554 7.343 3.078 10.625 4.575 3.283 1.496 6.119 3.049 8.51 4.66 2.39 1.611 4.276 3.366 5.658 5.265 1.382 1.899 2.073 4.057 2.073 6.474 0 1.784-.432 3.438-1.296 4.963-.864 1.524-2.174 2.848-3.93 3.97-1.756 1.122-3.945 1.999-6.565 2.632-2.62.633-5.687.949-9.2.949-5.989 0-11.92-1.05-17.794-3.151-5.874-2.1-11.317-5.25-16.327-9.451Zm-46.036-68.733H140V109H41v22.742h35.345V233h28.137V131.742Z"/></svg>',
    React:
      '<svg aria-hidden="true" class="fw-opt-icon" viewBox="-11.5 -10.232 23 20.463" width="16" height="16" fill="#00d1f7"><circle r="2.05"/><g stroke="#00d1f7" fill="none" stroke-width="1"><ellipse rx="11" ry="4.2"/><ellipse rx="11" ry="4.2" transform="rotate(60)"/><ellipse rx="11" ry="4.2" transform="rotate(120)"/></g></svg>',
    Vue: '<svg aria-hidden="true" class="fw-opt-icon" viewBox="0 0 196.32 170.02" width="16" height="16"><path fill="#42b883" d="M120.83 0L98.16 39.26 75.49 0H0l98.16 170.02L196.32 0h-75.49z"/><path fill="#35495e" d="M120.83 0L98.16 39.26 75.49 0H39.26l58.9 102.01L157.06 0h-36.23z"/></svg>',
    Angular:
      '<svg aria-hidden="true" class="fw-opt-icon" viewBox="0 0 960 960" width="16" height="16" fill="#f41343"><polygon points="562.6,109.8 804.1,629.5 829.2,233.1"/><polygon points="624.9,655.9 334.3,655.9 297.2,745.8 479.6,849.8 662,745.8"/><polygon points="384.1,539.3 575.2,539.3 479.6,307"/><polygon points="396.6,109.8 130,233.1 155.1,629.5"/></svg>',
  };

  class FwSelector extends HTMLElement {
    connectedCallback() {
      const select = this.querySelector('select');
      if (!select) return;

      // Enrich each option with its framework icon now that the browser
      // (not parse5) is the parser — rich <option> content is supported by
      // the customizable-select feature and renders correctly in the popup.
      for (const option of select.querySelectorAll<HTMLOptionElement>('option')) {
        const label = option.value;
        const icon = FW_ICONS[label];
        if (icon) option.innerHTML = `${icon}<span>${label}</span>`;
      }

      // To get the icon to also appear in the closed state, the <select>
      // needs a <button><selectedcontent></selectedcontent></button> as its
      // first child. The browser clones the selected option's full DOM into
      // <selectedcontent>. Inject at runtime — parse5 mangles
      // <selectedcontent> the same way it mangles rich <option> content.
      if (CSS.supports('appearance', 'base-select') && !select.querySelector(':scope > button')) {
        select.insertAdjacentHTML('afterbegin', '<button type="button"><selectedcontent></selectedcontent></button>');
      }

      const syncTabsToLabel = (label: string) => {
        for (const tabs of document.querySelectorAll<HTMLElement>('starlight-tabs[data-sync-key="framework"]')) {
          const tabLinks = [...tabs.querySelectorAll<HTMLAnchorElement>('[role="tab"]')];
          const idx = tabLinks.findIndex((t) => t.textContent?.trim() === label);
          if (idx !== -1) tabLinks[idx]?.click();
        }
      };

      // Sync dropdown to persisted value (with migration from legacy 'Vanilla JS' label).
      let saved = localStorage.getItem(FW_STORAGE_KEY) ?? '';
      let migrated = false;
      if (saved === 'Vanilla JS') {
        saved = 'TypeScript';
        localStorage.setItem(FW_STORAGE_KEY, saved);
        migrated = true;
      }
      if (saved) select.value = saved;
      // After migration, force-activate the renamed tab on already-rendered tab groups
      // (Starlight's own synced-tabs runtime won't have matched the legacy label).
      if (migrated) syncTabsToLabel(saved);

      select.addEventListener('change', () => {
        const label = select.value;
        localStorage.setItem(FW_STORAGE_KEY, label);
        syncTabsToLabel(label);
      });
    }
  }

  if (!customElements.get('fw-selector')) {
    customElements.define('fw-selector', FwSelector);
  }
</script>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    :global(:root:not([data-has-sidebar]) .title-wrapper .site-title) {
      display: none !important;
    }

    .center-group {
      flex: 1;
      align-items: center;
      gap: 0.5rem;
      max-width: var(--sl-content-width);
      width: 100%;
      place-self: center;
    }

    .right-group,
    .social-icons {
      gap: 1rem;
      align-items: center;
      justify-content: flex-end;
    }


    /* ----- Grid theme switcher select ----- */
    .theme-select-label {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.25rem;
      color: var(--sl-color-gray-1);
      cursor: pointer;
    }
    .theme-select-label:hover {
      color: var(--sl-color-gray-2);
    }

    .theme-select-icon,
    .theme-select-caret {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
    }
    .theme-select-icon {
      font-size: 0.875rem;
      inset-inline-start: 0;
    }
    .theme-select-caret {
      font-size: 1.25rem;
      inset-inline-end: 0;
    }

    .theme-select-label select {
      border: 0;
      padding-block: 0.625rem;
      padding-inline: calc(0.875rem + 0.5rem + 0.25rem) calc(1.25rem + 0.5rem + 0.25rem);
      margin-inline: -0.5rem;
      width: calc(7em + 1rem);
      background-color: transparent;
      text-overflow: ellipsis;
      color: inherit;
      cursor: pointer;
      appearance: none;
    }
    .theme-select-label option {
      background-color: var(--sl-color-bg-nav);
      color: var(--sl-color-gray-1);
    }

    /* ----- Framework selector ----- */
    .fw-select-label {
      display: flex;
      align-items: center;
      color: var(--sl-color-gray-1);
      cursor: pointer;
    }
    .fw-select-label:hover {
      color: var(--sl-color-gray-2);
    }

    /* Native fallback (Firefox / Safari / older Chrome): rich content inside <option>
       is flattened to text by the native picker, so users see plain framework names —
       acceptable degradation. The icons render in the closed state of the modern
       customizable <select> below via the auto-rendered selected option. */
    .fw-select-label select {
      border: 0;
      padding-block: 0.625rem;
      padding-inline: 0.5rem;
      margin-inline: -0.5rem;
      width: calc(8em + 1rem);
      background-color: transparent;
      color: inherit;
      cursor: pointer;
      appearance: none;
    }
    .fw-select-label option {
      background-color: var(--sl-color-bg-nav);
      color: var(--sl-color-gray-1);
    }

    /* Modern customizable <select> (Chrome 135+). Opt in via `appearance: base-select`.
       With no <button>/<selectedcontent>, the browser renders the selected <option>'s
       content (icon + label) as the closed display, and styled <option>s in the picker. */
    @supports (appearance: base-select) {
      .fw-select-label select,
      .fw-select-label select::picker(select) {
        appearance: base-select;
      }

      .fw-select-label select {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding-block: 0.5rem;
        padding-inline: 0.5rem;
        margin-inline: -0.5rem;
        width: calc(8em + 1rem);
        background: transparent;
        color: inherit;
        font: inherit;
      }
      .fw-select-label select::picker-icon {
        margin-inline-start: auto;
        opacity: 0.7;
        transition: rotate 0.15s ease;
      }
      .fw-select-label select:open::picker-icon {
        rotate: 180deg;
      }

      /* The closed-state <button><selectedcontent> is injected at runtime.
         <button> defaults to display:contents so the select's flex layout
         applies to its grandchildren — but the icon/label inside
         <selectedcontent> need their own gap. Wrapped in :global() because
         <selectedcontent> is injected at runtime and lacks Astro's scope class. */
      .fw-select-label select :global(selectedcontent) {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }

      .fw-select-label select::picker(select) {
        background-color: var(--sl-color-bg-nav);
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.375rem;
        padding: 0.25rem;
        box-shadow: 0 4px 12px rgb(0 0 0 / 0.15);
        color: var(--sl-color-gray-1);
        min-width: 10rem;
      }

      .fw-select-label option {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.25rem;
        background-color: transparent;
        color: var(--sl-color-gray-1);
        cursor: pointer;
      }
      .fw-select-label option:hover {
        background-color: var(--sl-color-gray-6);
      }
      .fw-select-label option:checked {
        background-color: var(--sl-color-accent-low);
        color: var(--sl-color-accent-high);
      }
      .fw-select-label option::checkmark {
        /* Hide the default checkmark — the icon already identifies the framework. */
        display: none;
      }

      .fw-opt-icon {
        flex-shrink: 0;
      }
    }


    @media (min-width: 50rem) {
      .theme-select-label select,
      .fw-select-label select {
        font-size: var(--sl-text-sm);
      }

      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        --__gutter: calc(
          (
            100% + var(--__sidebar-pad, 0rem) -
            var(--sl-content-inline-start, 0rem) -
            var(--sl-content-width) -
            var(--__toc-width, var(--sl-sidebar-width))
          ) / 2
        );
        display: grid;
        grid-template-columns:
          /* 1 (site title): left sidebar + gutter (can grow for long titles) */
          minmax(
            calc(
              max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x)) +
              max(0rem, var(--__gutter))
            ),
            auto
          )
          /* 2 (center): above main content */
          1fr
          /* 3 (right: social icons): tracks right sidebar width */
          max(0rem, calc(
            var(--__toc-width, var(--sl-sidebar-width)) - var(--sl-nav-pad-x) + var(--__gutter)
          ));
        align-content: center;
      }
    }
  }
</style>
