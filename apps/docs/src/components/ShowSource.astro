---
/**
 * ShowSource.astro — Wraps a live demo and adds a collapsible "Show source" panel.
 *
 * At BUILD TIME, reads the demo's `.astro` file, extracts the `<script>` content,
 * cleans it into an idiomatic code example (removing DOM boilerplate), and renders
 * it with Shiki syntax highlighting via Astro's `<Code>` component.
 *
 * Usage in MDX:
 * ```mdx
 * <ShowSource file="demos/filtering/FilteringDefaultDemo.astro">
 *   <FilteringDefaultDemo />
 * </ShowSource>
 * ```
 */
import { Code } from 'astro-expressive-code/components';

interface Props {
  /** Path to the demo .astro file, relative to src/components/ */
  file: string;
  /** Syntax highlighting language (default: typescript) */
  lang?: string;
}

const { file, lang = 'typescript' } = Astro.props;

// ---------------------------------------------------------------------------
// 1. Read demo file at build time
// ---------------------------------------------------------------------------
const demoFiles = import.meta.glob<string>('./demos/**/*.astro', {
  query: '?raw',
  import: 'default',
  eager: true,
});

const rawContent = demoFiles[`./${file}`] ?? '';

// ---------------------------------------------------------------------------
// 2. Extract and clean the <script> content
// ---------------------------------------------------------------------------

/**
 * Unwrap a top-level `if (guardVar) { ... }` block by removing the if-line
 * and closing brace, then dedenting the inner lines to match surrounding code.
 */
function unwrapGuardBlock(lines: string[], guardVar: string): string[] {
  const nonEmpty = lines.filter((l) => l.trim().length > 0);
  if (nonEmpty.length === 0) return lines;
  const baseIndent = Math.min(...nonEmpty.map((l) => l.search(/\S/)));

  // Find a top-level if-guard (within 2 spaces of base indent)
  let guardIndex = -1;
  for (let i = 0; i < lines.length; i++) {
    const indent = lines[i].search(/\S/);
    if (indent < 0 || indent > baseIndent + 2) continue;
    const trimmed = lines[i].trim();
    if (new RegExp(`^if\\s*\\(\\s*${guardVar}\\b`).test(trimmed) && trimmed.endsWith('{')) {
      guardIndex = i;
      break;
    }
  }

  if (guardIndex === -1) return lines;

  // Find matching closing brace via brace-depth counting
  let braceDepth = 0;
  let closeIndex = -1;
  for (let i = guardIndex; i < lines.length; i++) {
    for (const ch of lines[i]) {
      if (ch === '{') braceDepth++;
      if (ch === '}') braceDepth--;
    }
    if (braceDepth === 0) {
      closeIndex = i;
      break;
    }
  }

  if (closeIndex === -1) return lines; // Unbalanced — bail out

  const before = lines.slice(0, guardIndex);
  const inner = lines.slice(guardIndex + 1, closeIndex);
  const after = lines.slice(closeIndex + 1);

  // Dedent inner lines to align with the if-statement's indent level
  const guardIndent = lines[guardIndex].search(/\S/);
  const innerNonEmpty = inner.filter((l) => l.trim().length > 0);
  if (innerNonEmpty.length === 0) return [...before, ...after];
  const innerMinIndent = Math.min(...innerNonEmpty.map((l) => l.search(/\S/)));
  const stripAmount = innerMinIndent - guardIndent;

  const dedented = inner.map((line) => {
    if (line.trim() === '') return '';
    return stripAmount > 0 && line.length > stripAmount ? line.slice(stripAmount) : line;
  });

  return [...before, ...dedented, ...after];
}

function extractSource(content: string): string {
  const scriptMatch = content.match(/<script(?:\s[^>]*)?>(\r?\n)?([\s\S]*?)<\/script>/);
  if (!scriptMatch) return '';

  const code = scriptMatch[2];
  let lines = code.split('\n');

  // ── Step 1: Identify boilerplate variables ──
  // gridVar: the queryGrid result variable
  let gridVar: string | null = null;
  const gridMatch = code.match(/const\s+(\w+)\s*=\s*(?:await\s+)?queryGrid\b/);
  if (gridMatch) gridVar = gridMatch[1];

  // containerVar: the second arg to queryGrid (if it's a variable, not true/false/null)
  let containerVar: string | null = null;
  const containerMatch = code.match(/queryGrid\b[^(]*\(\s*(?:'[^']*'|"[^"]*")\s*,\s*([a-zA-Z_]\w*)/);
  if (containerMatch && !['true', 'false', 'null', 'undefined'].includes(containerMatch[1])) {
    containerVar = containerMatch[1];
  }

  // ── Step 2: Unwrap if-guard block (if present) ──
  const guardVar = containerVar || gridVar;
  if (guardVar) {
    lines = unwrapGuardBlock(lines, guardVar);
  }

  // ── Step 3: Filter and sanitize lines ──
  const imports: string[] = [];
  const body: string[] = [];
  let skipParenDepth = 0;

  for (const line of lines) {
    const trimmed = line.trim();

    // Skip import type
    if (trimmed.startsWith('import type')) continue;

    // Collect imports
    if (trimmed.startsWith('import ')) {
      imports.push(trimmed);
      continue;
    }

    // Skip container variable declaration
    if (containerVar && new RegExp(`^const\\s+${containerVar}\\s*=`).test(trimmed)) continue;

    // Skip negative guard one-liners: if (!grid) throw/return
    if (gridVar && new RegExp(`^if\\s*\\(\\s*!\\s*${gridVar}\\s*\\)`).test(trimmed)) continue;

    // Skip control-change addEventListener blocks (DemoControls wiring)
    if (skipParenDepth > 0) {
      for (const ch of trimmed) {
        if (ch === '(') skipParenDepth++;
        if (ch === ')') skipParenDepth--;
      }
      if (skipParenDepth <= 0) skipParenDepth = 0;
      continue;
    }
    if (containerVar && new RegExp(`\\b${containerVar}\\.addEventListener\\s*\\(\\s*'control-change'`).test(trimmed)) {
      skipParenDepth = 0;
      for (const ch of trimmed) {
        if (ch === '(') skipParenDepth++;
        if (ch === ')') skipParenDepth--;
      }
      if (skipParenDepth <= 0) skipParenDepth = 0;
      continue;
    }

    // Sanitize
    let processed = line;

    // Sanitize gridVar declaration: normalize queryGrid call to queryGrid('tbw-grid')
    if (gridVar && new RegExp(`^\\s*const\\s+${gridVar}\\s*=\\s*(?:await\\s+)?queryGrid\\b`).test(processed)) {
      const indent = processed.match(/^(\s*)/)?.[1] ?? '';
      const hasAwait = /\bawait\b/.test(processed);
      processed = `${indent}const ${gridVar} = ${hasAwait ? 'await ' : ''}queryGrid('tbw-grid');`;
    } else {
      // Sanitize any other inline queryGrid calls
      processed = processed.replace(
        /queryGrid(?:<[^>]+>)?\s*\(\s*(?:'[^']*'|"[^"]*")(?:\s*,\s*[^)]*?)?\)/g,
        "queryGrid('tbw-grid')",
      );
    }

    // container.querySelector(All) → document.querySelector(All)
    if (containerVar) {
      processed = processed.replace(new RegExp(`\\b${containerVar}\\.(querySelector(?:All)?)`, 'g'), 'document.$1');
    }

    // Strip TypeScript type assertions
    processed = processed.replace(/\s+as\s+HTMLElement\s*&\s*\{[^}]*\}/g, '');
    processed = processed.replace(/\s+as\s+(?:HTMLElement|Element|GridElement|EventListener|[A-Z]\w+)(?:<[^>]+>)?/g, '');

    body.push(processed);
  }

  // ── Step 4: Strip common indent from body lines ──
  const bodyNonEmpty = body.filter((l) => l.trim().length > 0);
  if (bodyNonEmpty.length > 0) {
    const minIndent = Math.min(...bodyNonEmpty.map((l) => l.search(/\S/)));
    if (minIndent > 0) {
      for (let i = 0; i < body.length; i++) {
        body[i] = body[i].trim() === '' ? '' : body[i].slice(minIndent);
      }
    }
  }

  const result = [...imports, '', ...body].join('\n');
  return result.replace(/^\n+/, '').replace(/\n{3,}/g, '\n\n').trim();
}

// ---------------------------------------------------------------------------
// 3. Extract meaningful HTML from the demo file
// ---------------------------------------------------------------------------
function extractHtml(content: string): string {
  const withoutFrontmatter = content.replace(/^---[\s\S]*?---\s*\n/, '');
  const htmlSection = withoutFrontmatter.match(/^([\s\S]*?)<script/);
  if (!htmlSection) return '';

  const html = htmlSection[1].trim();
  if (!html || !html.includes('<tbw-grid')) return '';

  // Extract the <tbw-grid>...</tbw-grid> block (handles child elements like <tbw-grid-column>)
  const gridMatch = html.match(/<tbw-grid[\s\S]*<\/tbw-grid>/);
  if (!gridMatch) return '';

  let result = gridMatch[0];

  // Strip demo-specific IDs
  result = result.replace(/\s+id="[^"]*"/g, '');

  // Re-indent from zero
  const lines = result.split('\n');
  const nonEmpty = lines.filter((l) => l.trim().length > 0);
  if (nonEmpty.length === 0) return '';
  const minIndent = Math.min(...nonEmpty.map((l) => l.search(/\S/)));

  return lines
    .map((l) => (l.trim() ? l.slice(minIndent) : ''))
    .join('\n')
    .trim();
}

const source = extractSource(rawContent);
const htmlSource = extractHtml(rawContent);

// Determine if the HTML is "simple" (a single self-closing <tbw-grid> tag, ≤2 lines)
// Simple HTML gets shown as a small stacked block above the JS; complex HTML gets its own tab.
const htmlLineCount = htmlSource ? htmlSource.split('\n').length : 0;
const isSimpleHtml = htmlSource && htmlLineCount <= 2 && !htmlSource.includes('<tbw-grid-column');
const complexHtml = htmlSource && !isSimpleHtml ? htmlSource : '';
const inlineHtml = isSimpleHtml ? htmlSource : '';
---

{source ? (
  <div class="show-source-wrapper not-content">
    <slot />
    <div class="demo-source-panel">
      <button class="demo-source-toggle" type="button" aria-expanded="false">
        <svg class="demo-source-chevron" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
          <polyline
            points="9 18 15 12 9 6"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span>Show source</span>
      </button>
      <div class="demo-source-content" hidden>
        {complexHtml ? (
          <div class="demo-source-tabs">
            <div class="demo-source-tab-bar" role="tablist">
              <button class="demo-source-tab active" role="tab" aria-selected="true" data-tab="js" type="button">JavaScript</button>
              <button class="demo-source-tab" role="tab" aria-selected="false" data-tab="html" type="button">HTML</button>
            </div>
            <div class="demo-source-tab-panel" data-panel="js">
              <div class="demo-source-code-wrap">
                <Code code={source} lang={lang} />
              </div>
            </div>
            <div class="demo-source-tab-panel" data-panel="html" hidden>
              <div class="demo-source-code-wrap">
                <Code code={complexHtml} lang="html" />
              </div>
            </div>
          </div>
        ) : (
          <div class="demo-source-stacked">
            {inlineHtml && (
              <div class="demo-source-code-wrap demo-source-html-inline">
                <Code code={inlineHtml} lang="html" title="HTML" />
              </div>
            )}
            <div class="demo-source-code-wrap">
              <Code code={source} lang={lang} />
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
) : (
  <slot />
)}

<script>
  document.addEventListener('click', (e) => {
    const toggle = (e.target as HTMLElement).closest('.demo-source-toggle');
    if (toggle) {
      const content = toggle.nextElementSibling as HTMLElement | null;
      if (!content) return;
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      content.hidden = expanded;
      const label = toggle.querySelector('span');
      if (label) label.textContent = expanded ? 'Show source' : 'Hide source';
      return;
    }

    // Tab switching for HTML/JS tabs
    const tab = (e.target as HTMLElement).closest('.demo-source-tab') as HTMLElement | null;
    if (tab) {
      const tabBar = tab.parentElement;
      if (!tabBar) return;
      const tabs = tabBar.querySelectorAll('.demo-source-tab');
      const wrapper = tabBar.closest('.demo-source-tabs');
      if (!wrapper) return;
      const panels = wrapper.querySelectorAll('.demo-source-tab-panel');
      const targetKey = tab.dataset.tab;

      tabs.forEach((t) => {
        t.classList.toggle('active', t === tab);
        t.setAttribute('aria-selected', String(t === tab));
      });
      panels.forEach((p: Element) => {
        (p as HTMLElement).hidden = (p as HTMLElement).dataset.panel !== targetKey;
      });
    }
  });
</script>

<style>
  /* --- Wrapper: connects demo and source panel visually --- */
  .show-source-wrapper {
    margin: 1.5rem 0;
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  .show-source-wrapper > :global(.grid-demo),
  .show-source-wrapper > :global(.grid-playground) {
    margin: 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  /* --- Source panel --- */
  .demo-source-panel {
    position: relative;
    border-top: none;
    background: var(--sl-color-gray-7);
  }

  .demo-source-content {
    border: 1px solid var(--sl-color-gray-5);
    border-top: 0;
    border-radius: 0 0 8px 8px;
    overflow: hidden;
  }

  /* --- Toggle button --- */
  .demo-source-toggle {
    position: absolute;
    top: -26px;
    right: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    transition: color 0.15s;
  }

  .demo-source-toggle:hover {
    color: var(--sl-color-text);
  }

  .demo-source-chevron {
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .demo-source-toggle[aria-expanded='true'] .demo-source-chevron {
    transform: rotate(90deg);
  }

  /* --- Code block --- */
  .demo-source-code-wrap {
    position: relative;
  }

  .demo-source-code-wrap :global(pre) {
    margin: 0 !important;
    border-radius: 0 !important;
    border: none !important;
    max-height: 500px;
    padding: .5rem;
  }

  /* --- Stacked HTML + JS blocks --- */
  .demo-source-stacked {
    display: flex;
    flex-direction: column;
  }

  .demo-source-html-inline {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }

  .demo-source-html-inline :global(.expressive-code) {
    margin: 0 !important;
  }

  /* --- Tab bar for HTML/JS --- */
  .demo-source-tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
  }

  .demo-source-tab {
    padding: 0.4rem 1rem;
    border: none;
    background: transparent;
    color: var(--sl-color-gray-3);
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .demo-source-tab:hover {
    color: var(--sl-color-text);
  }

  .demo-source-tab.active {
    color: var(--sl-color-text);
    border-bottom-color: var(--sl-color-text-accent);
  }


</style>
