---
// IntroShowcaseDemo.astro — Rich, feature-packed hero grid demo for the landing page.
// Showcases: selection, filtering, editing, sorting, custom renderers, pinned columns,
// column groups, footer aggregations — all in one impressive demo.
---
<div class="grid-demo not-content">
  <tbw-grid style="display: block; height: 430px; font-size: 13px;" data-demo-id="intro-showcase"></tbw-grid>
</div>

<script>
