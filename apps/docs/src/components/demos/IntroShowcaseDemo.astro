    price: number;
    change: number;
    changePct: number;
    volume: number;
    marketCap: number;
    pe: number;
    high52w: number;
    low52w: number;
    avgVolume: number;
    rating: 'Strong Buy' | 'Buy' | 'Hold' | 'Sell' | 'Strong Sell';
  }

  const tickers: Ticker[] = [
    { ticker: 'AAPL', company: 'Apple Inc.', sector: 'Technology', price: 227.63, change: 3.42, changePct: 1.53, volume: 54_320_100, marketCap: 3_480_000, pe: 37.2, high52w: 260.10, low52w: 164.08, avgVolume: 48_500_000, rating: 'Strong Buy' },
