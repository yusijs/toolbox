---
// PerformanceComparisonDemo.astro — Head-to-head benchmark: Toolbox Grid vs AG Grid
// Loads AG Grid Community from CDN (always latest). Iterates through increasing
// data sizes (1K → 1M rows), testing each grid sequentially at every scale point
// with a cooldown between them for a fair comparison.
---
<div class="perf-compare-wrapper not-content">
  <div class="perf-compare-bar">
    <div class="perf-compare-bar-left">
      <button id="compare-run" class="perf-compare-btn">Run Comparison</button>
      <span id="compare-status">Ready</span>
    </div>
    <div class="perf-compare-bar-right">
      <span id="compare-versions" style="font-size:12px;opacity:0.7;"></span>
    </div>
  </div>

  <div id="compare-progress" class="perf-compare-progress" style="display:none;">
    <div id="compare-progress-bar" class="perf-compare-progress-fill"></div>
  </div>

  <details id="compare-config-details" class="perf-compare-config">
    <summary>Show Grid Configurations</summary>
    <div class="perf-compare-config-panels">
      <div class="perf-compare-config-panel">
        <h4>Toolbox Grid</h4>
        <pre id="compare-config-tbw"><code>// Configuration displayed here</code></pre>
      </div>
      <div class="perf-compare-config-panel">
        <h4>AG Grid Community <span id="ag-version" style="font-weight:normal;opacity:0.7;font-size:12px;"></span></h4>
        <pre id="compare-config-ag"><code>// Configuration displayed here</code></pre>
      </div>
    </div>
  </details>

  <div id="compare-grid-area" class="perf-compare-grid-area">
    <p style="text-align:center;opacity:0.6;padding:40px 0;">Grid will render here during benchmarks (one at a time)</p>
  </div>

  <div id="compare-results" class="perf-compare-results">
    <p>Click <strong>Run Comparison</strong> to benchmark both grids at increasing data sizes.</p>
    <p style="opacity:0.7;font-size:12px;">Scale points: 1K → 10K → 100K → 500K → 1M rows × 10 columns. Tests: init render, scroll, sort, data replacement, single-row update, column resize, scroll-to-end, memory. Each grid runs alone with a cooldown between them.</p>
  </div>
</div>

<script>
  import '@toolbox-web/grid';
import type { ColumnConfig } from '@toolbox-web/grid';
import { queryGrid } from '@toolbox-web/grid';
import '@toolbox-web/grid/features/column-virtualization';
import '@toolbox-web/grid/features/filtering';
import '@toolbox-web/grid/features/multi-sort';
import '@toolbox-web/grid/features/selection';

  // #region Constants
  const SCALE_POINTS = [1_000, 10_000, 100_000, 500_000, 1_000_000];
  const COL_COUNT = 10;
  const TIME_METRICS = [
    'Initial render', 'Scroll avg frame', 'Sort', 'Data replacement',
    'Update single row', 'Column resize', 'Scroll to end',
  ] as const;
  const MEMORY_METRIC = 'Memory usage' as const;
  const ALL_METRICS = [...TIME_METRICS, MEMORY_METRIC] as const;
  type MetricName = typeof ALL_METRICS[number];
  const hasMemoryApi = !!(performance as any).memory;
  // #endregion

  // #region Types & Helpers
  interface ScaleResult {
    rowCount: number;
    tbw: Map<string, number>;
    ag: Map<string, number>;
  }

  function generateColumns(count: number): { field: string; header: string; width: number }[] {
    const columns: { field: string; header: string; width: number }[] = [
      { field: 'id', header: 'ID', width: 80 },
    ];
    for (let i = 1; i < count; i++) {
      columns.push({ field: `col${i}`, header: `Column ${i}`, width: 120 });
    }
    return columns;
  }

  function generateRows(rowCount: number, columnCount: number): Record<string, unknown>[] {
    const rows: Record<string, unknown>[] = [];
    for (let i = 0; i < rowCount; i++) {
      const row: Record<string, unknown> = { id: i + 1 };
      for (let j = 1; j < columnCount; j++) {
        row[`col${j}`] = `R${i + 1}C${j}`;
      }
      rows.push(row);
    }
    return rows;
  }

  function formatTime(ms: number): string {
    if (ms < 1) return `${(ms * 1000).toFixed(0)}µs`;
    if (ms < 1000) return `${ms.toFixed(1)}ms`;
    return `${(ms / 1000).toFixed(2)}s`;
  }

  function formatBytes(bytes: number): string {
    if (bytes < 1024) return `${bytes}B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)}KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)}MB`;
  }

  function formatMetric(metric: string, value: number): string {
    return metric === MEMORY_METRIC ? formatBytes(value) : formatTime(value);
  }

  function formatRowCount(n: number): string {
    if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(0)}M`;
    if (n >= 1_000) return `${(n / 1_000).toFixed(0)}K`;
    return String(n);
  }

  const nextFrame = () => new Promise<void>((r) => requestAnimationFrame(() => requestAnimationFrame(() => r())));

  const cooldown = (ms = 500) => new Promise<void>((r) => setTimeout(r, ms));

  const measure = async (fn: () => void | Promise<void>): Promise<number> => {
    await nextFrame();
    const start = performance.now();
    await fn();
    await nextFrame();
    return performance.now() - start;
  };

  function measureMemory(): number | null {
    const mem = (performance as any).memory;
    return mem ? mem.usedJSHeapSize : null;
  }
  // #endregion

  // #region AG Grid Loader
  let agGridLoaded = false;
  let agGridVersion = '';

  async function loadAgGrid(): Promise<void> {
    if (agGridLoaded) return;

    try {
      const res = await fetch('https://cdn.jsdelivr.net/npm/ag-grid-community/package.json');
      if (res.ok) {
        const pkg = await res.json();
        agGridVersion = pkg.version || '';
        const versionEl = document.getElementById('ag-version');
        if (versionEl) versionEl.textContent = `v${agGridVersion}`;
      }
    } catch { /* version display is optional */ }

    return new Promise((resolve, reject) => {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://cdn.jsdelivr.net/npm/ag-grid-community/styles/ag-grid.min.css';
      document.head.appendChild(link);

      const themeLink = document.createElement('link');
      themeLink.rel = 'stylesheet';
      themeLink.href = 'https://cdn.jsdelivr.net/npm/ag-grid-community/styles/ag-theme-quartz.min.css';
      document.head.appendChild(themeLink);

      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.js';
      script.onload = () => { agGridLoaded = true; resolve(); };
      script.onerror = () => reject(new Error('Failed to load AG Grid from CDN'));
      document.head.appendChild(script);
    });
  }
  // #endregion

  // #region Toolbox Grid Benchmarks (single scale point)
  async function runToolboxAtScale(
    gridArea: HTMLElement,
    rowCount: number,
  ): Promise<Map<string, number>> {
    const results = new Map<string, number>();
    const columns = generateColumns(COL_COUNT);
    const rows = generateRows(rowCount, COL_COUNT);

    gridArea.innerHTML = '<tbw-grid id="compare-tbw-grid" style="width:100%;height:100%;"></tbw-grid>';
    const grid = queryGrid('#compare-tbw-grid')!;
    await cooldown(100);

    const tbwColumns: ColumnConfig[] = columns.map((c) => ({
      field: c.field, header: c.header, width: c.width,
      type: c.field === 'id' ? 'number' : 'string', sortable: true,
    }));

    // Initial render
    const renderTime = await measure(() => {
      grid.gridConfig = {
        columns: tbwColumns,
        fitMode: 'fixed',
        getRowId: (row: any) => String(row.id),
        features: { selection: 'range', multiSort: { maxSortColumns: 3 } },
      };
      grid.rows = rows;
    });
    results.set('Initial render', renderTime);
    await cooldown(200);

    // Scroll
    const scrollContainer = grid.querySelector('.faux-vscroll');
    if (scrollContainer) {
      const totalHeight = scrollContainer.scrollHeight;
      const viewportHeight = scrollContainer.clientHeight;
      const steps = 30;
      const stepSize = (totalHeight - viewportHeight) / steps;
      if (stepSize > 0) {
        for (let i = 0; i <= steps; i++) { scrollContainer.scrollTop = i * stepSize; await nextFrame(); }
        scrollContainer.scrollTop = 0;
        await cooldown(50);
        const frameTimes: number[] = [];
        for (let i = 0; i <= steps; i++) {
          const start = performance.now();
          scrollContainer.scrollTop = i * stepSize;
          await nextFrame();
          frameTimes.push(performance.now() - start);
        }
        results.set('Scroll avg frame', frameTimes.reduce((a, b) => a + b, 0) / frameTimes.length);
        scrollContainer.scrollTop = 0;
        await cooldown(50);
      }
    }

    // Sort
    const sortPlugin = (grid as any).getPluginByName?.('multiSort') as { setSortModel: (m: unknown[]) => void; clearSort: () => void } | undefined;
    if (sortPlugin) {
      const sortTime = await measure(() => { sortPlugin.setSortModel([{ field: 'id', direction: 'desc' }]); });
      results.set('Sort', sortTime);
      sortPlugin.clearSort();
      await cooldown(50);
    }

    // Data replacement
    const newRows = generateRows(rowCount, COL_COUNT);
    const replaceTime = await measure(() => { grid.rows = newRows; });
    results.set('Data replacement', replaceTime);
    await cooldown(50);

    // Update single row
    if ((grid as any).updateRow) {
      const updateTime = await measure(() => {
        (grid as any).updateRow(String(Math.floor(rowCount / 2) + 1), { col1: 'UPDATED' });
      });
      results.set('Update single row', updateTime);
      await cooldown(50);
    }

    // Column resize
    const resizeTime = await measure(() => {
      const state = (grid as any).getColumnState?.();
      if (state?.columns?.[0]) {
        state.columns[0].width = 200;
        (grid as any).columnState = state;
      }
    });
    results.set('Column resize', resizeTime);
    await cooldown(50);

    // Scroll to end
    const scrollEndTime = await measure(() => {
      (grid as any).scrollToRow?.(rowCount - 1, { align: 'end' });
    });
    results.set('Scroll to end', scrollEndTime);
    await cooldown(50);

    // Memory usage (Chrome only)
    const mem = measureMemory();
    if (mem !== null) results.set('Memory usage', mem);

    // Cleanup
    grid.rows = [];
    grid.gridConfig = { columns: [] };
    gridArea.innerHTML = '';
    await cooldown(300);

    return results;
  }
  // #endregion

  // #region AG Grid Benchmarks (single scale point)
  async function runAgAtScale(
    gridArea: HTMLElement,
    rowCount: number,
  ): Promise<Map<string, number>> {
    const results = new Map<string, number>();
    const agGrid = (window as any).agGrid;
    if (!agGrid) throw new Error('AG Grid not loaded');

    const columns = generateColumns(COL_COUNT);
    const rows = generateRows(rowCount, COL_COUNT);

    gridArea.innerHTML = '<div id="compare-ag-grid" class="ag-theme-quartz" style="width:100%;height:100%;"></div>';
    const container = document.getElementById('compare-ag-grid')!;
    await cooldown(100);

    const agColumnDefs = columns.map((c) => ({
      field: c.field, headerName: c.header, width: c.width, sortable: true,
    }));

    // Initial render
    let gridApi: any;
    const renderTime = await measure(() => {
      gridApi = agGrid.createGrid(container, {
        columnDefs: agColumnDefs, rowData: rows,
        suppressColumnVirtualisation: false, animateRows: false,
        getRowId: (params: any) => String(params.data.id),
      });
    });
    results.set('Initial render', renderTime);
    await cooldown(200);

    // Scroll
    const agScrollViewport = container.querySelector('.ag-body-viewport');
    if (agScrollViewport) {
      const totalHeight = agScrollViewport.scrollHeight;
      const viewportHeight = agScrollViewport.clientHeight;
      const steps = 30;
      const stepSize = (totalHeight - viewportHeight) / steps;
      if (stepSize > 0) {
        for (let i = 0; i <= steps; i++) { agScrollViewport.scrollTop = i * stepSize; await nextFrame(); }
        agScrollViewport.scrollTop = 0;
        await cooldown(50);
        const frameTimes: number[] = [];
        for (let i = 0; i <= steps; i++) {
          const start = performance.now();
          agScrollViewport.scrollTop = i * stepSize;
          await nextFrame();
          frameTimes.push(performance.now() - start);
        }
        results.set('Scroll avg frame', frameTimes.reduce((a, b) => a + b, 0) / frameTimes.length);
        agScrollViewport.scrollTop = 0;
        await cooldown(50);
      }
    }

    // Sort
    if (gridApi) {
      const sortTime = await measure(() => {
        gridApi.applyColumnState({ state: [{ colId: 'id', sort: 'desc' }] });
      });
      results.set('Sort', sortTime);
      gridApi.applyColumnState({ defaultState: { sort: null } });
      await cooldown(50);
    }

    // Data replacement
    const newRows = generateRows(rowCount, COL_COUNT);
    const replaceTime = await measure(() => { gridApi.setGridOption('rowData', newRows); });
    results.set('Data replacement', replaceTime);
    await cooldown(50);

    // Update single row
    if (gridApi) {
      const midId = Math.floor(rowCount / 2) + 1;
      const updateTime = await measure(() => {
        gridApi.applyTransaction({ update: [{ id: midId, col1: 'UPDATED' }] });
      });
      results.set('Update single row', updateTime);
      await cooldown(50);
    }

    // Column resize
    if (gridApi) {
      const resizeTime = await measure(() => {
        gridApi.applyColumnState({ state: [{ colId: 'id', width: 200 }] });
      });
      results.set('Column resize', resizeTime);
      await cooldown(50);
    }

    // Scroll to end
    if (gridApi) {
      const scrollEndTime = await measure(() => {
        gridApi.ensureIndexVisible(rowCount - 1, 'bottom');
      });
      results.set('Scroll to end', scrollEndTime);
      await cooldown(50);
    }

    // Memory usage (Chrome only)
    const mem = measureMemory();
    if (mem !== null) results.set('Memory usage', mem);

    // Cleanup
    if (gridApi) gridApi.destroy();
    gridArea.innerHTML = '';
    await cooldown(300);

    return results;
  }
  // #endregion

  // #region Results Rendering
  const COLOR_TBW = '#38bdf8'; // cyan — Toolbox brand
  const COLOR_AG = '#fb923c';  // orange — AG Grid brand
  const COLOR_WIN = '#4ade80'; // green — winner value
  const COLOR_LOSE = '#f87171'; // red — loser value

  function formatDelta(winner: number, loser: number): string {
    if (loser === 0 || winner === 0) return '';
    const ratio = loser / winner;
    if (ratio < 1.05) return '';
    return `${ratio.toFixed(1)}×`;
  }

  function renderScaleTable(allResults: ScaleResult[], done: boolean): string {
    // Determine which metrics have data
    const activeMetrics = ALL_METRICS.filter((metric) =>
      allResults.some((r) => r.tbw.has(metric) || r.ag.has(metric))
    );

    // Legend + card grid
    let html = `<div class="perf-legend">
      <span class="perf-legend-item"><span class="perf-legend-swatch" style="background:${COLOR_TBW}"></span> Toolbox Grid</span>
      <span class="perf-legend-item"><span class="perf-legend-swatch" style="background:${COLOR_AG}"></span> AG Grid</span>
      <span class="perf-legend-hint">Lower is better · <span style="color:${COLOR_WIN}">green</span> = winner</span>
    </div>`;
    html += '<div class="perf-card-grid">';

    for (const metric of activeMetrics) {
      // Find max value for bar scaling
      let maxVal = 0;
      for (const r of allResults) {
        maxVal = Math.max(maxVal, r.tbw.get(metric) ?? 0, r.ag.get(metric) ?? 0);
      }
      if (maxVal === 0) maxVal = 1;

      html += `<div class="perf-card">
        <div class="perf-card-title">${metric}</div>`;

      for (const r of allResults) {
        const tbw = r.tbw.get(metric);
        const ag = r.ag.get(metric);
        const tbwDone = tbw !== undefined;
        const agDone = ag !== undefined;
        const bothDone = tbwDone && agDone;
        const tbwWins = bothDone && (tbw!) <= (ag!);
        const agWins = bothDone && (ag!) < (tbw!);

        const tbwPct = tbwDone ? Math.max(3, ((tbw!) / maxVal) * 100) : 0;
        const agPct = agDone ? Math.max(3, ((ag!) / maxVal) * 100) : 0;

        const tbwLabel = tbwDone ? formatMetric(metric, tbw!) : '…';
        const agLabel = agDone ? formatMetric(metric, ag!) : '…';

        // Bar always uses brand color; value text uses green/red for winner/loser
        const tbwValColor = bothDone ? (tbwWins ? COLOR_WIN : COLOR_LOSE) : '#888';
        const agValColor = bothDone ? (agWins ? COLOR_WIN : COLOR_LOSE) : '#888';

        const tbwDelta = tbwWins ? formatDelta(tbw!, ag!) : '';
        const agDelta = agWins ? formatDelta(ag!, tbw!) : '';

        html += `
          <div class="perf-row">
            <div class="perf-row-label">${formatRowCount(r.rowCount)}</div>
            <div class="perf-row-bars">
              <div class="perf-bar-row perf-bar-row-top">
                <span class="perf-bar-name" style="color:${COLOR_TBW}">TBW</span>
                <div class="perf-bar-track">
                  <div class="perf-bar-fill" style="width:${tbwPct}%;background:${COLOR_TBW};"></div>
                </div>
                <span class="perf-bar-value" style="color:${tbwValColor}">${tbwLabel}${tbwDelta ? ` <span class="perf-delta">${tbwDelta}</span>` : ''}</span>
              </div>
              <div class="perf-bar-row perf-bar-row-bottom">
                <span class="perf-bar-name" style="color:${COLOR_AG}">AG</span>
                <div class="perf-bar-track">
                  <div class="perf-bar-fill" style="width:${agPct}%;background:${COLOR_AG};"></div>
                </div>
                <span class="perf-bar-value" style="color:${agValColor}">${agLabel}${agDelta ? ` <span class="perf-delta">${agDelta}</span>` : ''}</span>
              </div>
            </div>
          </div>`;
      }

      html += '</div>';
    }

    html += '</div>';

    if (done) {
      // Summary: count wins across all scale points and metrics
      let tbwWins = 0;
      let agWins = 0;
      for (const r of allResults) {
        for (const metric of activeMetrics) {
          const tbw = r.tbw.get(metric);
          const ag = r.ag.get(metric);
          if (tbw !== undefined && ag !== undefined) {
            if (tbw < ag) tbwWins++; else if (ag < tbw) agWins++;
          }
        }
      }
      html += `
        <div class="perf-summary">
          <span style="color:${COLOR_TBW}">▎Toolbox Grid</span> wins <strong>${tbwWins}/${tbwWins + agWins}</strong> data points
          <div style="color:#888;font-size:12px;margin-top:4px;">
            Tested at ${SCALE_POINTS.map(formatRowCount).join(', ')} rows × ${COL_COUNT} columns${hasMemoryApi ? ' — memory via Chrome performance.memory' : ''}
          </div>
        </div>
      `;
    }

    return html;
  }
  // #endregion

  // #region DOM References
  const runBtn = document.getElementById('compare-run') as HTMLButtonElement;
  const statusEl = document.getElementById('compare-status')!;
  const resultsEl = document.getElementById('compare-results')!;
  const gridArea = document.getElementById('compare-grid-area')!;
  const progressContainer = document.getElementById('compare-progress')!;
  const progressBar = document.getElementById('compare-progress-bar')!;
  const versionsEl = document.getElementById('compare-versions')!;

  // Populate config panels (set via JS to avoid Astro template parsing of curly braces)
  const tbwConfigEl = document.getElementById('compare-config-tbw')!;
  const agConfigEl = document.getElementById('compare-config-ag')!;
  tbwConfigEl.textContent = [
    'grid.gridConfig = {',
    '  columns: [',
    "    { field: 'id', header: 'ID', width: 80, type: 'number', sortable: true },",
    '    // ... 9 more columns, width: 120, sortable: true',
    '  ],',
    "  fitMode: 'fixed',",
    '  getRowId: (row) => String(row.id),',
    '  features: {',
    "    selection: 'range',",
    '    multiSort: { maxSortColumns: 3 },',
    '  },',
    '};',
    'grid.rows = data; // 1K \u2192 1M rows',
  ].join('\n');
  agConfigEl.textContent = [
    'agGrid.createGrid(container, {',
    '  columnDefs: [',
    "    { field: 'id', headerName: 'ID', width: 80, sortable: true },",
    '    // ... 9 more columns, width: 120, sortable: true',
    '  ],',
    '  rowData: data, // 1K \u2192 1M rows',
    '  getRowId: (params) => String(params.data.id),',
    '  suppressColumnVirtualisation: false,',
    '  animateRows: false,',
    '});',
  ].join('\n');
  // #endregion

  // #region Benchmark Orchestrator
  runBtn.addEventListener('click', async () => {
    runBtn.disabled = true;
    progressContainer.style.display = 'block';

    // Load AG Grid from CDN
    statusEl.textContent = 'Loading AG Grid from CDN...';
    try {
      await loadAgGrid();
    } catch {
      statusEl.textContent = 'Failed to load AG Grid from CDN';
      runBtn.disabled = false;
      progressContainer.style.display = 'none';
      return;
    }
    versionsEl.textContent = agGridVersion ? `AG Grid v${agGridVersion} (latest from CDN)` : '';

    const allResults: ScaleResult[] = SCALE_POINTS.map((rowCount) => ({
      rowCount,
      tbw: new Map(),
      ag: new Map(),
    }));

    const totalSteps = SCALE_POINTS.length * 2; // tbw + ag per scale point
    let completedSteps = 0;

    const updateProgress = () => {
      const pct = Math.round((completedSteps / totalSteps) * 100);
      progressBar.style.width = `${pct}%`;
    };

    for (let i = 0; i < SCALE_POINTS.length; i++) {
      const rowCount = SCALE_POINTS[i];
      const label = formatRowCount(rowCount);

      // Phase 1: Toolbox Grid at this scale point
      statusEl.textContent = `Toolbox Grid — ${label} rows (${i + 1}/${SCALE_POINTS.length})`;
      gridArea.innerHTML = `<p style="text-align:center;opacity:0.6;padding:20px 0;">⏱ Toolbox Grid — ${label} rows...</p>`;
      await cooldown(200);

      const tbwResults = await runToolboxAtScale(gridArea, rowCount);
      allResults[i].tbw = tbwResults;
      completedSteps++;
      updateProgress();
      resultsEl.innerHTML = renderScaleTable(allResults, false);

      // Cooldown between grids
      statusEl.textContent = `Cooldown before AG Grid — ${label} rows...`;
      gridArea.innerHTML = '<p style="text-align:center;opacity:0.4;padding:20px 0;">Cooldown...</p>';
      await cooldown(1000);

      // Phase 2: AG Grid at this scale point
      statusEl.textContent = `AG Grid — ${label} rows (${i + 1}/${SCALE_POINTS.length})`;
      gridArea.innerHTML = `<p style="text-align:center;opacity:0.6;padding:20px 0;">⏱ AG Grid — ${label} rows...</p>`;
      await cooldown(200);

      const agResults = await runAgAtScale(gridArea, rowCount);
      allResults[i].ag = agResults;
      completedSteps++;
      updateProgress();
      resultsEl.innerHTML = renderScaleTable(allResults, false);

      // Cooldown before next scale point
      if (i < SCALE_POINTS.length - 1) {
        statusEl.textContent = `Cooldown before ${formatRowCount(SCALE_POINTS[i + 1])} rows...`;
        gridArea.innerHTML = '<p style="text-align:center;opacity:0.4;padding:20px 0;">Cooldown...</p>';
        await cooldown(1000);
      }
    }

    // Final results
    gridArea.innerHTML = '<p style="text-align:center;opacity:0.6;padding:20px 0;">Benchmark complete</p>';
    statusEl.textContent = `Complete — ${SCALE_POINTS.map(formatRowCount).join(' → ')} rows` + (agGridVersion ? ` — AG Grid v${agGridVersion}` : '');
    resultsEl.innerHTML = renderScaleTable(allResults, true);
    progressBar.style.width = '100%';
    runBtn.disabled = false;

    // Console log
    for (const metric of ALL_METRICS) {
      console.groupCollapsed(`📊 ${metric}`);
      console.table(allResults.map((r) => ({
        Rows: formatRowCount(r.rowCount),
        Toolbox: r.tbw.get(metric),
        'AG Grid': r.ag.get(metric),
      })));
      console.groupEnd();
    }
  });
  // #endregion
</script>

<style is:global>
  .perf-compare-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 500px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    overflow: hidden;
  }

  .perf-compare-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: 13px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .perf-compare-bar-left,
  .perf-compare-bar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .perf-compare-btn {
    background: var(--sl-color-accent);
    color: #fff;
    border: none;
    padding: 6px 14px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
  }

  .perf-compare-btn:hover { opacity: 0.9; }
  .perf-compare-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  #compare-status {
    font-size: 13px;
    color: var(--sl-color-gray-2);
  }

  .perf-compare-progress {
    height: 3px;
    background: var(--sl-color-gray-5);
    overflow: hidden;
  }

  .perf-compare-progress-fill {
    height: 100%;
    width: 0;
    background: var(--sl-color-accent);
    transition: width 0.3s;
  }

  .perf-compare-config {
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
  }

  .perf-compare-config summary {
    padding: 8px 12px;
    cursor: pointer;
    font-size: 13px;
    color: var(--sl-color-gray-2);
    user-select: none;
  }

  .perf-compare-config summary:hover {
    color: var(--sl-color-white);
  }

  .perf-compare-config-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 0 12px 12px;
  }

  .perf-compare-config-panel {
    background: var(--sl-color-gray-7, #111);
    border-radius: 4px;
    padding: 10px;
    overflow-x: auto;
  }

  .perf-compare-config-panel h4 {
    margin: 0 0 8px 0;
    font-size: 13px;
    color: var(--sl-color-white, #e5e5e5);
  }

  .perf-compare-config-panel pre {
    margin: 0;
    font-size: 11px;
    line-height: 1.5;
    white-space: pre-wrap;
    color: var(--sl-color-gray-2);
  }

  .perf-compare-grid-area {
    height: 300px;
    padding: 8px;
    overflow: hidden;
  }

  .perf-compare-results {
    border-top: 1px solid var(--sl-color-gray-5);
    padding: 12px 16px;
    font-size: 14px;
    line-height: 1.5;
    max-height: 70vh;
    overflow-y: auto;
  }

  .perf-compare-results p {
    margin: 0 0 8px 0;
  }

  /* Legend */
  .perf-legend {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
    font-size: 12px;
    color: var(--sl-color-gray-2);
    flex-wrap: wrap;
  }

  .perf-legend-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-weight: 600;
    color: var(--sl-color-white, #e5e5e5);
  }

  .perf-legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
  }

  .perf-legend-hint {
    font-size: 11px;
    color: var(--sl-color-gray-3, #999);
    margin-left: auto;
  }

  /* Card grid layout */
  .perf-card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  @media (max-width: 700px) {
    .perf-card-grid { grid-template-columns: 1fr; }
  }

  .perf-card {
    background: var(--sl-color-gray-6, #1e1e1e);
    border-radius: 6px;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .perf-card-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--sl-color-white, #e5e5e5);
    margin-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .perf-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 3px 0;
  }

  .perf-row + .perf-row {
    border-top: 1px solid var(--sl-color-gray-5, #333);
  }

  .perf-row-label {
    font-family: monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--sl-color-white, #e5e5e5);
    min-width: 28px;
    text-align: right;
  }

  .perf-row-bars {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  .perf-bar-row {
    display: flex;
    align-items: center;
    gap: 4px;
    height: 10px;
  }

  .perf-bar-row-top {
    /* flush against bottom bar */
  }

  .perf-bar-row-bottom {
    /* flush against top bar */
  }

  .perf-bar-name {
    font-size: 9px;
    font-weight: 700;
    font-family: monospace;
    min-width: 22px;
    text-align: right;
  }

  .perf-bar-track {
    flex: 1;
    height: 10px;
    background: var(--sl-color-gray-7, #111);
    border-radius: 2px;
    overflow: hidden;
  }

  .perf-bar-row-top .perf-bar-track {
    border-radius: 2px 2px 0 0;
  }

  .perf-bar-row-bottom .perf-bar-track {
    border-radius: 0 0 2px 2px;
  }

  .perf-bar-fill {
    height: 100%;
    border-radius: inherit;
    transition: width 0.3s;
  }

  .perf-bar-value {
    font-family: monospace;
    font-size: 10px;
    min-width: 70px;
    text-align: right;
    white-space: nowrap;
  }

  .perf-delta {
    font-size: 9px;
    opacity: 0.8;
  }

  .perf-summary {
    margin-top: 10px;
    padding: 12px;
    background: var(--sl-color-gray-6, #1e1e1e);
    border-radius: 6px;
    text-align: center;
    color: var(--sl-color-white, #e5e5e5);
    font-size: 14px;
  }
</style>
