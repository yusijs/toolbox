---
// ClipboardEventsDemo.astro — Shows copy/paste events with a live log panel
---
<div class="grid-demo not-content" id="clipboard-events-demo">
  <p style="font-size: 0.85em; color: var(--sl-color-gray-3); margin: 0 0 8px;">
    Select cells and use <kbd>Ctrl+C</kbd> / <kbd>Ctrl+V</kbd> to copy and paste.
  </p>
  <tbw-grid id="demo-clipboard-events" style="height: 260px;"></tbw-grid>
  <div class="log-panel">
    <div class="log-header">
      <strong>Event Log:</strong>
      <button id="clear-clipboard-events-log">Clear</button>
    </div>
    <div class="event-log" id="clipboard-events-log"></div>
  </div>
</div>

<style>
  #clipboard-events-demo .log-panel {
    border: 1px solid var(--sl-color-gray-5);
    padding: 12px;
    border-radius: 4px;
    background: var(--sl-color-gray-6);
    overflow-y: auto;
    max-height: 200px;
    margin-top: 8px;
  }
  #clipboard-events-demo .log-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  #clipboard-events-demo .log-header button {
    padding: 4px 8px;
    cursor: pointer;
    font-size: 12px;
  }
  #clipboard-events-demo .event-log {
    font-family: monospace;
    font-size: 11px;
    color: var(--sl-color-gray-2);
  }
  #clipboard-events-demo .event-log > div {
    padding: 2px 0;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  #clipboard-events-demo .event-log .event-type {
    color: var(--sl-color-accent);
  }
</style>

<script>
import '@toolbox-web/grid';
import { queryGrid } from '@toolbox-web/grid';
import '@toolbox-web/grid/features/clipboard';
import '@toolbox-web/grid/features/selection';

const container = document.getElementById('clipboard-events-demo');
if (container) {
  const grid = queryGrid('tbw-grid', container);

  grid.gridConfig = {
    columns: [
      { field: 'name', header: 'Name' },
      { field: 'department', header: 'Department' },
      { field: 'salary', header: 'Salary', type: 'number', align: 'right' },
    ],
    features: {
      selection: 'range',
      clipboard: true,
    },
  };

  grid.rows = [
    { name: 'Alice Johnson', department: 'Engineering', salary: 95000 },
    { name: 'Bob Smith', department: 'Marketing', salary: 75000 },
    { name: 'Carol White', department: 'Sales', salary: 68000 },
    { name: 'David Brown', department: 'Engineering', salary: 92000 },
    { name: 'Eve Davis', department: 'HR', salary: 65000 },
  ];

  const log = container.querySelector('#clipboard-events-log');
  const clearBtn = container.querySelector('#clear-clipboard-events-log');

  function addLog(type: string, detail: string) {
    if (!log) return;
    const msg = document.createElement('div');
    msg.innerHTML = `<span class="event-type">[${type}]</span> ${detail}`;
    log.insertBefore(msg, log.firstChild);
    while (log.children.length > 15) log.lastChild?.remove();
  }

  clearBtn?.addEventListener('click', () => { if (log) log.innerHTML = ''; });

  grid.on('copy', (d) => {
    addLog('copy', `${d.rowCount} row(s), ${d.columnCount} column(s)`);
  });

  grid.on('paste', (d) => {
    addLog('paste', `${d.rows.length} row(s), fields: ${d.fields.join(', ')}`);
  });
}
</script>
