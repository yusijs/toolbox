---
// PivotDefaultDemo.astro
import DemoControls from '@components/DemoControls.astro';
---
<div class="grid-demo not-content" id="pivot-default-demo">
  <DemoControls controls={[
    { section: 'PIVOT', name: 'active', label: 'Active', type: 'boolean',
      default: true, description: 'Whether pivot is active' },
    { section: 'PIVOT', name: 'aggFunc', label: 'Aggregation', type: 'select',
      options: ['sum', 'avg', 'count', 'min', 'max'], default: 'sum', description: 'Aggregation function' },
    { section: 'PIVOT', name: 'showTotals', label: 'Show total column', type: 'boolean',
      default: true, description: 'Show the per-row Total column on the right' },
    { section: 'PIVOT', name: 'showGrandTotal', label: 'Show grand total', type: 'boolean',
      default: true, description: 'Show grand total row at the bottom' },
    { section: 'PIVOT', name: 'grandTotalInRowModel', label: 'Grand total in row model', type: 'boolean',
      default: false, description: 'Render grand total as a regular row instead of a sticky footer (useful for export/copy)' },
    { section: 'PIVOT', name: 'showToolPanel', label: 'Show tool panel', type: 'boolean',
      default: true, description: 'Show drag-and-drop tool panel' },
    { section: 'PIVOT', name: 'defaultExpanded', label: 'Default expanded', type: 'boolean',
      default: true, description: 'Groups expanded by default' },
    { section: 'PIVOT', name: 'indentWidth', label: 'Indent width', type: 'number',
      default: 20, min: 0, max: 60, description: 'Indent per depth level (px)' },
    { section: 'PIVOT', name: 'animation', label: 'Animation', type: 'select',
      options: ['slide', 'fade', 'false'], default: 'slide', description: 'Expand/collapse animation' },
    { section: 'SORTING', name: 'sortRowsBy', label: 'Sort rows by', type: 'select',
      options: ['none', 'label', 'value'], default: 'none', description: 'Sort row groups' },
    { section: 'SORTING', name: 'sortRowsDir', label: 'Sort rows direction', type: 'select',
      options: ['asc', 'desc'], default: 'asc', description: 'Sort direction for rows' },
    { section: 'SORTING', name: 'sortColumns', label: 'Sort columns', type: 'select',
      options: ['none', 'asc', 'desc'], default: 'none', description: 'Sort column keys' },
  ]} />
  <tbw-grid style="height: 400px;"></tbw-grid>
</div>

<script>
import '@toolbox-web/grid';
import { queryGrid } from '@toolbox-web/grid';
import '@toolbox-web/grid/features/pivot';

const container = document.getElementById('pivot-default-demo');
if (container) {
  const salesData = [
    { region: 'North', product: 'Widget A', quarter: 'Q1', sales: 1200 },
    { region: 'North', product: 'Widget B', quarter: 'Q1', sales: 800 },
    { region: 'North', product: 'Widget A', quarter: 'Q2', sales: 1500 },
    { region: 'North', product: 'Widget B', quarter: 'Q2', sales: 950 },
    { region: 'South', product: 'Widget A', quarter: 'Q1', sales: 900 },
    { region: 'South', product: 'Widget B', quarter: 'Q1', sales: 1100 },
    { region: 'South', product: 'Widget A', quarter: 'Q2', sales: 1300 },
    { region: 'South', product: 'Widget B', quarter: 'Q2', sales: 1400 },
    { region: 'East', product: 'Widget A', quarter: 'Q1', sales: 750 },
    { region: 'East', product: 'Widget B', quarter: 'Q1', sales: 650 },
    { region: 'East', product: 'Widget A', quarter: 'Q2', sales: 880 },
    { region: 'East', product: 'Widget B', quarter: 'Q2', sales: 720 },
  ];
  const columns = [
    { field: 'region', header: 'Region' },
    { field: 'product', header: 'Product' },
    { field: 'quarter', header: 'Quarter' },
    { field: 'sales', header: 'Sales', type: 'number' },
  ];

  const grid = queryGrid('tbw-grid', container)!;

  function rebuild(opts: Record<string, unknown>) {
    const aggFunc = (opts.aggFunc as string) ?? 'sum';
    const headerLabel = aggFunc === 'sum' ? 'Total Sales'
      : aggFunc === 'avg' ? 'Avg Sales'
      : aggFunc === 'count' ? 'Count'
      : aggFunc === 'min' ? 'Min Sales'
      : 'Max Sales';
    const animRaw = (opts.animation as string) ?? 'slide';
    const animation = animRaw === 'false' ? false : animRaw;
    const sortRowsBy = (opts.sortRowsBy as string) ?? 'none';
    const sortRowsDir = (opts.sortRowsDir as string) ?? 'asc';
    const sortColumnsRaw = (opts.sortColumns as string) ?? 'none';
    const valueField: Record<string, unknown> = {
      field: 'sales', aggFunc, header: headerLabel,
      format: (v: number) => `$${v.toLocaleString()}`,
    };
    const pivotConfig: Record<string, unknown> = {
      active: opts.active as boolean ?? true,
      animation,
      rowGroupFields: ['region', 'product'],
      columnGroupFields: ['quarter'],
      valueFields: [valueField],
      showTotals: opts.showTotals as boolean ?? true,
      showGrandTotal: opts.showGrandTotal as boolean ?? true,
      grandTotalInRowModel: opts.grandTotalInRowModel as boolean ?? false,
      showToolPanel: opts.showToolPanel as boolean ?? true,
      defaultExpanded: opts.defaultExpanded as boolean ?? true,
      indentWidth: opts.indentWidth as number ?? 20,
    };
    if (sortRowsBy !== 'none') {
      pivotConfig.sortRows = { by: sortRowsBy, direction: sortRowsDir };
    }
    if (sortColumnsRaw !== 'none') {
      pivotConfig.sortColumns = sortColumnsRaw;
    }
    grid.gridConfig = {
      columns,
      features: { pivot: pivotConfig as any },
    };
    grid.rows = salesData;
  }

  rebuild({ active: true, showTotals: true, showGrandTotal: true, grandTotalInRowModel: false, showToolPanel: true, defaultExpanded: true, indentWidth: 20, animation: 'slide', aggFunc: 'sum', sortRowsBy: 'none', sortRowsDir: 'asc', sortColumns: 'none' });

  container.addEventListener('control-change', ((e: CustomEvent) => {
    rebuild(e.detail.allValues);
  }) as EventListener);
}
</script>
