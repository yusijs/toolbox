---
// PrintToolbarButtonDemo.astro
---
<div class="grid-demo not-content" id="print-toolbar-button-demo">
  <tbw-grid style="display: block; height: 400px;"></tbw-grid>
</div>

<script>
import '@toolbox-web/grid';
import { queryGrid } from '@toolbox-web/grid';

import '@toolbox-web/grid/features/print';

const container = document.getElementById('print-toolbar-button-demo');
if (container) {
  const grid = queryGrid('tbw-grid', container);

  const employeeData = [
    { id: 1, name: 'Alice Johnson', department: 'Engineering', salary: 85000 },
    { id: 2, name: 'Bob Smith', department: 'Marketing', salary: 72000 },
    { id: 3, name: 'Carol Williams', department: 'Engineering', salary: 92000 },
    { id: 4, name: 'David Brown', department: 'Sales', salary: 68000 },
    { id: 5, name: 'Emma Davis', department: 'HR', salary: 65000 },
    { id: 6, name: 'Frank Miller', department: 'Engineering', salary: 88000 },
    { id: 7, name: 'Grace Wilson', department: 'Marketing', salary: 75000 },
    { id: 8, name: 'Henry Taylor', department: 'Sales', salary: 70000 },
  ];

  grid.gridConfig = {
    shell: {
      header: {
        title: 'Employee Directory',
      },
    },
    columns: [
      { field: 'id', header: 'ID', width: 60 },
      { field: 'name', header: 'Name', width: 180 },
      { field: 'department', header: 'Department', width: 120 },
      { field: 'salary', header: 'Salary', width: 100 },
    ],
    features: {
      print: {
        button: true,
        title: 'Employee Directory',
        isolate: true,
      },
    },
  };
  grid.rows = employeeData;
}
</script>
