{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Performance baseline for regression detection in CI",
  "type": "object",
  "required": ["baseline"],
  "properties": {
    "$schema": { "type": "string" },
    "baseline": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["runner", "date", "metrics"],
          "properties": {
            "runner": {
              "type": "string",
              "description": "Runner label (e.g. github-actions-ubuntu-latest)"
            },
            "date": {
              "type": "string",
              "format": "date",
              "description": "ISO date when the baseline was recorded"
            },
            "metrics": {
              "type": "object",
              "additionalProperties": {
                "type": "number",
                "description": "Median metric value in milliseconds"
              },
              "description": "Map of metric name → median value (ms)"
            }
          }
        }
      ]
    }
  }
}
