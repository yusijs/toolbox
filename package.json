{
  "name": "@toolbox-web/components",
  "version": "0.2.9",
  "license": "MIT",
  "author": "Oystein Amundsen",
  "repository": {
    "type": "git",
    "url": "https://github.com/OysteinAmundsen/toolbox.git"
  },
  "homepage": "https://toolboxjs.com",
  "bugs": {
    "url": "https://github.com/OysteinAmundsen/toolbox/issues"
  },
  "scripts": {
    "nx": "nx",
    "start": "nx serve docs",
    "build": "rm -rf dist/libs/ && nx run-many --target=build --exclude=docs --output-style=stream && bun run cem",
    "cem": "cd libs/grid && bunx cem analyze",
    "test": "nx run-many --target=test --exclude=demo-angular --output-style=stream --silent",
    "e2e": "nx run-many --target=e2e",
    "e2e:update": "nx e2e:update-snapshots e2e",
    "e2e:full": "bun run build && concurrently --kill-others --success first -n servers,e2e -c gray,magenta \"bun run demo:dist\" \"bunx wait-on http://localhost:4000 http://localhost:4300 http://localhost:4200 http://localhost:4100 -t 60000 && bun run e2e\"",
    "demo": "concurrently --kill-others -n vanilla,react,angular,vue -c blue,green,yellow,cyan \"bun nx run demo-vanilla:serve\" \"bun nx run demo-react:serve\" \"bun nx run demo-angular:serve\" \"bun nx run demo-vue:serve\"",
    "demo:dist": "concurrently --kill-others -n vanilla,react,angular,vue -c blue,green,yellow,cyan \"bun nx run demo-vanilla:serve:dist\" \"bun nx run demo-react:serve:dist\" \"bun nx run demo-angular:serve:dist\" \"bun nx run demo-vue:serve:dist\"",
    "lint": "nx run-many --target=lint --output-style=stream --quiet",
    "coverage": "bun run test --coverage",
    "build:libs": "nx run-many --target=build --projects=grid,grid-angular,grid-react,grid-vue --output-style=stream --skip-nx-cache",
    "build:watch": "bun scripts/watch-libs.ts",
    "link:push": "bash -c 'for dir in dist/libs/*/; do [ -f \"${dir}package.json\" ] && (cd \"$dir\" && bunx yalc push --sig); done' || true",
    "dev": "bun run build:libs && bun run link:push && bun run build:watch",
    "update": "nx migrate latest && nx migrate --run-migrations --if-exists && git commit -am 'chore: update dependencies' && bunx npm-check-updates --format group -u --cooldown 5 --target minor && bun install"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.3",
    "@astrojs/cloudflare": "12.6.12",
    "@astrojs/mdx": "4.3.13",
    "@astrojs/starlight": "0.37.7",
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@eslint/js": "9.39.4",
    "@estruyf/github-actions-reporter": "1.11.0",
    "@nx/angular": "22.6.1",
    "@nx/devkit": "22.6.1",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/playwright": "22.6.1",
    "@nx/vite": "22.6.1",
    "@nx/vitest": "22.6.1",
    "@nx/web": "22.6.1",
    "@playwright/test": "1.58.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.18",
    "@swc/helpers": "0.5.19",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "5.2.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "astro": "5.18.1",
    "astro-mermaid": "1.3.1",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "happy-dom": "20.8.4",
    "jsdom": "27.4.0",
    "jsonc-eslint-parser": "2.4.2",
    "mermaid": "11.13.0",
    "ng-packagr": "21.2.1",
    "nx": "22.6.1",
    "pagefind": "1.4.0",
    "prettier": "3.8.1",
    "rollup-plugin-cleanup": "3.2.1",
    "rxjs": "7.8.2",
    "ts-node": "10.9.2",
    "tslib": "2.8.1",
    "typedoc": "0.28.17",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vite": "7.3.1",
    "vite-plugin-dts": "4.5.4",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0",
    "vue": "3.5.30",
    "wait-on": "9.0.4"
  },
  "workspaces": [
    "libs/*",
    "apps/*"
  ],
  "overrides": {
    "@angular/core": "21.2.5",
    "@angular/common": "21.2.5",
    "@angular/compiler": "21.2.5",
    "@angular/forms": "21.2.5",
    "@angular/platform-browser": "21.2.5",
    "@angular/router": "21.2.5",
    "@angular/compiler-cli": "21.2.5"
  }
}
